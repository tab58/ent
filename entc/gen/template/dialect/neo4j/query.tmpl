{{/* gotype: entgo.io/ent/entc/gen.typeScope */}}

{{ define "dialect/neo4j/query" }}
{{ $builder := pascal $.Scope.Builder }}
{{ $receiver := $.Scope.Receiver }}

func ({{ $receiver }} *{{ $builder }}) neo4jAll(ctx context.Context, hooks ...queryHook) ([]*{{ $.Name }}, error) {
	res := &neo4j.Response{}
	b := {{ $receiver }}.neo4jQuery(ctx)
	if len({{ $receiver }}.ctx.Fields) > 0 {
		fields := make([]string, len({{ $receiver }}.ctx.Fields))
		for i, f := range {{ $receiver }}.ctx.Fields {
			fields[i] = fmt.Sprintf("n.%s", f)
		}
		b.Return(fields...)
	} else {
		b.Return("n {.*}")
	}
	query, params := b.Query()
	if err := {{ $receiver }}.driver.Exec(ctx, query, params, res); err != nil {
		return nil, err
	}
	var {{ plural $.Receiver }} {{ plural $.Name }}
	if err := {{ plural $.Receiver }}.FromResponse(res); err != nil {
		return nil, err
	}
	for i := range {{ plural $.Receiver }} {
		{{ plural $.Receiver }}[i].config = {{ $receiver }}.config
	}
	return {{ plural $.Receiver }}, nil
}

func ({{ $receiver }} *{{ $builder }}) neo4jCount(ctx context.Context) (int, error) {
	res := &neo4j.Response{}
	b := {{ $receiver }}.neo4jQuery(ctx)
	b.Return("count(n)")
	query, params := b.Query()
	if err := {{ $receiver }}.driver.Exec(ctx, query, params, res); err != nil {
		return 0, err
	}
	return res.ReadInt()
}

func ({{ $receiver }} *{{ $builder }}) neo4jQuery(context.Context) *cypher.Builder {
	var b *cypher.Builder
	if {{ $receiver }}.neo4j != nil {
		b = {{ $receiver }}.neo4j.Clone()
	} else {
		b = cypher.New()
		b.Match(fmt.Sprintf("(n:%s)", {{ $.Package }}.Label))
	}
	for _, p := range {{ $receiver }}.predicates {
		p(b)
	}
	if len({{ $receiver }}.order) > 0 {
		for _, p := range {{ $receiver }}.order {
			p(b)
		}
	}
	switch limit, offset := {{ $receiver }}.ctx.Limit, {{ $receiver }}.ctx.Offset; {
	case limit != nil && offset != nil:
		b.Skip(*offset)
		b.Limit(*limit)
	case offset != nil:
		b.Skip(*offset)
	case limit != nil:
		b.Limit(*limit)
	}
	return b
}
{{ end }}

{{/* query/path defines the query generation for path of a given edge. */}}
{{ define "dialect/neo4j/query/path" }}
	{{- $e := $.Scope.Edge }}
	{{- $receiver := $.Scope.Receiver }}
	{{- $ident := $.Scope.Ident }}
	{{- $name := printf "%s.%s" $.Package $e.LabelConstant }}
	{{- if $e.IsInverse }}
		{{- $name = printf "%s.%s" $e.Type.Package $e.LabelConstant }}
	{{- end }}
	gremlin := {{ $receiver }}.neo4jQuery(ctx)
	{{- if $e.Bidi }}
		{{ $ident }} = gremlin.Match(fmt.Sprintf("(n)-[:%s]-(m:%s)", {{ $name }}, {{ $e.Type.Package }}.Label))
	{{- else if $e.IsInverse }}
		{{ $ident }} = gremlin.Match(fmt.Sprintf("(n)<-[:%s]-(m:%s)", {{ $name }}, {{ $e.Type.Package }}.Label))
	{{- else }}
		{{ $ident }} = gremlin.Match(fmt.Sprintf("(n)-[:%s]->(m:%s)", {{ $name }}, {{ $e.Type.Package }}.Label))
	{{- end }}
{{ end }}

{{/* query/from defines the query generation for an edge query from a given node. */}}
{{ define "dialect/neo4j/query/from" }}
	{{- $n := $ }}
	{{- $e := $.Scope.Edge }}
	{{- $receiver := $.Scope.Receiver }}
	{{- $ident := $.Scope.Ident }}
	{{- $name := printf "%s.%s" $n.Package $e.LabelConstant }}
	{{- if $e.IsInverse }}
		{{- $name = printf "%s.%s" $e.Type.Package $e.LabelConstant }}
	{{- end }}
	b := cypher.New()
	idP := b.AddParam({{ $receiver }}.ID)
	{{- if $e.Bidi }}
		b.Match(fmt.Sprintf("(n:%s {id: %s})-[:%s]-(m:%s)", {{ $n.Package }}.Label, idP, {{ $name }}, {{ $e.Type.Package }}.Label))
	{{- else if $e.IsInverse }}
		b.Match(fmt.Sprintf("(n:%s {id: %s})<-[:%s]-(m:%s)", {{ $n.Package }}.Label, idP, {{ $name }}, {{ $e.Type.Package }}.Label))
	{{- else }}
		b.Match(fmt.Sprintf("(n:%s {id: %s})-[:%s]->(m:%s)", {{ $n.Package }}.Label, idP, {{ $name }}, {{ $e.Type.Package }}.Label))
	{{- end }}
	{{ $ident }} = b
{{ end }}
