{{/* gotype: entgo.io/ent/entc/gen.typeScope */}}

{{ define "dialect/neo4j/create" }}
{{ $builder := pascal $.Scope.Builder }}
{{ $receiver := $.Scope.Receiver }}
{{ $mutation := print $receiver ".mutation"  }}

func ({{ $receiver }} *{{ $builder }}) neo4jSave(ctx context.Context) (*{{ $.Name }}, error) {
	if err := {{ $receiver }}.check(); err != nil {
		return nil, err
	}
	res := &neo4j.Response{}
	query, params := {{ $receiver }}.neo4j().Query()
	if err := {{ $receiver }}.driver.Exec(ctx, query, params, res); err != nil {
		return nil, err
	}
	if err, ok := isConstraintError(res); ok {
		return nil, err
	}
	rnode := &{{ $.Name }}{config: {{ $receiver }}.config}
	if err := rnode.FromResponse(res); err != nil {
		return nil, err
	}
	{{- if $.HasOneFieldID }}
		{{ $mutation }}.{{ $.ID.BuilderField }} = &rnode.{{ $.ID.StructField }}
		{{ $mutation }}.done = true
	{{- end }}
	return rnode, nil
}

func ({{ $receiver }} *{{ $builder }}) neo4j() *cypher.Builder {
	b := cypher.New()
	{{- /* Build property assignments for CREATE. */}}
	props := make([]string, 0)
	{{- if $.ID.UserDefined }}
		if id, ok := {{ $mutation }}.{{ $.ID.MutationGet }}(); ok {
			p := b.AddParam(id)
			props = append(props, fmt.Sprintf("id: %s", p))
		}
	{{- else }}
		{{- /* KSUID assignment for auto-generated IDs. */}}
		p := b.AddParam({{ $mutation }}.id)
		props = append(props, fmt.Sprintf("id: %s", p))
	{{- end }}
	{{- range $f := $.MutationFields }}
		if value, ok := {{ $mutation }}.{{ $f.MutationGet }}(); ok {
			{{- if $f.Unique }}
				{{- /* Uniqueness guard via OPTIONAL MATCH. */}}
				existP := b.AddParam(value)
				b.Match(fmt.Sprintf("OPTIONAL MATCH (existing:%s {%s: %s})", {{ $.Package }}.Label, {{ $.Package }}.{{ $f.Constant }}, existP))
				b.Where("existing IS NULL")
			{{- end }}
			p := b.AddParam(value)
			props = append(props, fmt.Sprintf("%s: %s", {{ $.Package }}.{{ $f.Constant }}, p))
		}
	{{- end }}
	b.Create(fmt.Sprintf("(n:%s {%s})", {{ $.Package }}.Label, strings.Join(props, ", ")))
	{{- range $e := $.Edges }}
		{{- $name := printf "%s.%s" $.Package $e.LabelConstant }}
		{{- if $e.IsInverse }}
			{{- $name = printf "%s.%s" $e.Type.Package $e.LabelConstant }}
		{{- end }}
		for _, id := range {{ $mutation }}.{{ $e.StructField }}IDs() {
			edgeP := b.AddParam(id)
			b.Match(fmt.Sprintf("WITH n MATCH (m:%s) WHERE m.id = %s", {{ $e.Type.Package }}.Label, edgeP))
			{{- if $e.IsInverse }}
				b.Create(fmt.Sprintf("(m)-[:%s]->(n)", {{ $name }}))
			{{- else }}
				b.Create(fmt.Sprintf("(n)-[:%s]->(m)", {{ $name }}))
			{{- end }}
		}
	{{- end }}
	b.Return("n {.*}")
	return b
}
{{ end }}
